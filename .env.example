# CreditPilot — Frontend environment variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────

# Your Supabase project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ── Demo mode ─────────────────────────────────────────────────────────────────

# Set to true to use pre-seeded demo data without burning API tokens.
# Set to false when running against real customer data.
VITE_DEMO_MODE=true
